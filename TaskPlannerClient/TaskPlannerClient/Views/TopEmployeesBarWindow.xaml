<Window x:Class="TaskPlannerClient.Views.TopEmployeesBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:TaskPlannerClient.Views"
        mc:Ignorable="d"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Топ сотрудников по часам" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="TeamFilterCombo" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="TeamName" SelectedValuePath="IdTeam"
                      materialDesign:HintAssist.Hint="Команда"
                      Width="200" Margin="0,0,10,0" SelectionChanged="RefreshData"/>
            <TextBox x:Name="LimitTextBox" Text="5" Width="80"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Кол-во" Margin="0,0,10,0"/>
            <Button x:Name="RefreshButton" Content="Обновить" 
                    Style="{StaticResource MaterialDesignFlatButton}" Click="RefreshButton_Click"/>
        </StackPanel>

        <lvc:CartesianChart x:Name="BarChart" Grid.Row="1"
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            LegendPosition="Bottom"/>
    </Grid>
</Window>

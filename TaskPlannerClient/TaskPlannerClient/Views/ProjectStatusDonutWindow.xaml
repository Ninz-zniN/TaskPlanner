<Window x:Class="TaskPlannerClient.Views.ProjectStatusDonutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:local="clr-namespace:TaskPlannerClient.Views"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Статусы проекта" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="ProjectCombo" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="ProjectName" SelectedValuePath="IdProject"
                      materialDesign:HintAssist.Hint="Проект"
                      Width="250" SelectionChanged="ProjectCombo_SelectionChanged"/>
        </StackPanel>

        <lvc:PieChart x:Name="DonutChart" Grid.Row="1"
                      Series="{Binding Series}"
                      TooltipPosition="Top"
                      LegendPosition="Right"/>
    </Grid>
</Window>

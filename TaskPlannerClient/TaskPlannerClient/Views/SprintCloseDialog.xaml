<Window x:Class="TaskPlannerClient.Views.SprintCloseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskPlannerClient.Views"
        mc:Ignorable="d"
        Title="Закрытие спринта" Height="270" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите действие для незавершённых задач:" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,15"/>

        <Button x:Name="MoveToNextButton" Content="Перенести в следующий спринт" 
                Style="{StaticResource MaterialDesignRaisedButton}"
                Click="MoveToNextButton_Click" Grid.Row="1" Margin="0,0,0,10"/>

        <Button x:Name="MoveToBacklogButton" Content="Отвязать от спринта" 
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Click="MoveToBacklogButton_Click" Grid.Row="2" Margin="0,0,0,10"/>

        <Button x:Name="CancelTasksButton" Content="Отменить все незавершённые задачи" 
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Click="CancelTasksButton_Click" Grid.Row="3" Margin="0,0,0,10"
                Foreground="{DynamicResource MaterialDesignErrorForeground}"/>
        
        <Button x:Name="CancelButton" Content="Отмена" 
                Style="{StaticResource MaterialDesignFlatButton}"
                Click="CancelButton_Click" Grid.Row="4"/>
    </Grid>
</Window>

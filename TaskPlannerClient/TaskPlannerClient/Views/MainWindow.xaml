<Window x:Class="TaskPlannerClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:TaskPlannerClient.Views"
        mc:Ignorable="d"
            Title="Планировщик" Height="700" Width="1100"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с информацией о пользователе и кнопками -->
        <Border Grid.Row="0" Background="{StaticResource MaterialDesignPaper}" 
        Padding="15,10" Margin="0,0,0,5">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Планировщик задач" FontSize="20" FontWeight="Bold" 
                       VerticalAlignment="Center"/>
                    <TextBlock x:Name="UserInfoText" FontSize="14" 
                       VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Кнопка «Отчёты» — видна только manager и admin -->
                    <Button x:Name="ReportsButton" Content="Отчёты" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Visibility="Collapsed"
                    Click="ReportsButton_Click" Margin="0,0,10,0"/>
                    <Button x:Name="LogoutButton" Content="Выйти" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контейнер вкладок -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" 
                    Style="{StaticResource MaterialDesignTabControl}"
                    Margin="10,0,10,10"/>

        <!-- Индикатор загрузки (можно показывать при длительных операциях) -->
        <ProgressBar x:Name="LoadingProgress" Grid.RowSpan="2" 
                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                     Width="50" Height="50" Visibility="Collapsed"
                     VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>
</Window>

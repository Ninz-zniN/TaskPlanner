<Window x:Class="TaskPlannerClient.Views.ProjectDeviationBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskPlannerClient.Views"
        mc:Ignorable="d"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Отклонения по задачам" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="ProjectCombo" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="ProjectName" SelectedValuePath="IdProject"
                      materialDesign:HintAssist.Hint="Завершённый проект"
                      Width="300" SelectionChanged="ProjectCombo_SelectionChanged"/>
        </StackPanel>

        <lvc:CartesianChart x:Name="BarChart" Grid.Row="1"
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            LegendPosition="Bottom"/>
    </Grid>
</Window>

<Window x:Class="TaskPlannerClient.Views.EmployeeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskPlannerClient.Views"
        mc:Ignorable="d"
        Title="Сотрудник" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Фамилия" FontWeight="Bold" Grid.Row="0"/>
            <TextBox x:Name="LastNameTextBox" Grid.Row="1" Margin="0,5,0,10"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <TextBlock Text="Имя" FontWeight="Bold" Grid.Row="2"/>
            <TextBox x:Name="FirstNameTextBox" Grid.Row="3" Margin="0,5,0,10"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <TextBlock Text="Отчество" FontWeight="Bold" Grid.Row="4"/>
            <TextBox x:Name="PatronymicTextBox" Grid.Row="5" Margin="0,5,0,10"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <TextBlock Text="Должность" FontWeight="Bold" Grid.Row="6"/>
            <TextBox x:Name="PositionTextBox" Grid.Row="7" Margin="0,5,0,10"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

            <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="0,10">
                <StackPanel Width="200">
                    <TextBlock Text="Грейд" FontWeight="Bold"/>
                    <ComboBox x:Name="GradeComboBox" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="Intern"/>
                        <ComboBoxItem Content="Junior"/>
                        <ComboBoxItem Content="Middle"/>
                        <ComboBoxItem Content="Senior"/>
                        <ComboBoxItem Content="Lead"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Width="200" Margin="20,0,0,0">
                    <TextBlock Text="Часов в день" FontWeight="Bold"/>
                    <TextBox x:Name="HoursTextBox" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Команда" FontWeight="Bold" Grid.Row="9"/>
            <ComboBox x:Name="TeamComboBox" Grid.Row="10" Margin="0,5,0,10"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="TeamName" SelectedValuePath="IdTeam"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="11" Margin="0,10,0,0">
                <Button x:Name="SaveButton" Content="Сохранить" Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="SaveButton_Click" Margin="0,0,10,0"/>
                <Button Content="Отмена" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>

<UserControl x:Class="TaskPlannerClient.Views.Tabs.Admin.UserManagementTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:TaskPlannerClient.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Admin"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="AddButton" Content="Добавить пользователя" Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="AddButton_Click"/>
            <Button x:Name="RefreshButton" Content="Обновить" Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="10,0,0,0" Click="RefreshButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="UsersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="120"/>
                <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="70"/>
                <DataGridTextColumn Header="Сотрудник" Width="*">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0} {1}">
                            <Binding Path="employee.LastName"/>
                            <Binding Path="employee.FirstName"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Действия" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏️" ToolTip="Редактировать" Style="{StaticResource MaterialDesignIconButton}"
                                        Click="EditButton_Click" Tag="{Binding}"/>
                                <Button Content="🚫" ToolTip="Заблокировать" Style="{StaticResource MaterialDesignIconButton}"
                                        Click="BlockButton_Click" Tag="{Binding}"
                                        Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <!-- Кнопка разблокировки (видна, если пользователь неактивен) -->
                                <Button Content="🔓" ToolTip="Разблокировать" Style="{StaticResource MaterialDesignIconButton}"
                                    Click="UnblockButton_Click" Tag="{Binding}"
                                    Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=inverse}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

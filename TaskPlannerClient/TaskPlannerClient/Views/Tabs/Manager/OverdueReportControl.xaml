<UserControl x:Class="TaskPlannerClient.Views.Tabs.Manager.OverdueReportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Manager"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <Button Content="Просрочка по исполнителям" Click="OverdueByAssigneeButton_Click" 
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Margin="0,5,0,5" HorizontalAlignment="Left"/>
        </StackPanel>
        <DataGrid x:Name="OverdueDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Grid.Row="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Задача" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Дедлайн" Binding="{Binding Deadline, StringFormat='yyyy-MM-dd'}" Width="115"/>
                <DataGridTextColumn Header="Исполнитель" Binding="{Binding Assignee.LastName}" Width="115"/>
                <DataGridTextColumn Header="Проект" Binding="{Binding Project.Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

<UserControl x:Class="TaskPlannerClient.Views.Tabs.Manager.LoadReportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Manager"
             xmlns:converters="clr-namespace:TaskPlannerClient.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:LoadToColorConverter x:Key="LoadToColorConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Фильтр по команде -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="TeamFilterCombo" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="TeamName" SelectedValuePath="IdTeam"
                      materialDesign:HintAssist.Hint="Команда"
                      Width="200" SelectionChanged="TeamFilter_SelectionChanged"/>
            <Button x:Name="RefreshButton" Content="Обновить" Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="10,0,0,0" Click="RefreshButton_Click"/>
            <Button Content="Топ сотрудников" Click="TopEmployeesButton_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
        </StackPanel>

        <DataGrid x:Name="LoadDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.LastName}" Width="*"/>
                <DataGridTextColumn Header="Текущие часы" Binding="{Binding CurrentLoadHours}" Width="auto"/>
                <DataGridTextColumn Header="Ёмкость (часы)" Binding="{Binding CapacityHours}" Width="auto"/>
                <DataGridTemplateColumn Header="Загрузка %" Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding LoadPercent, Converter={StaticResource LoadToColorConverter}}" 
                                    CornerRadius="4" Padding="4">
                                <TextBlock Text="{Binding LoadPercent, StringFormat='{}{0:F1}%'}" 
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

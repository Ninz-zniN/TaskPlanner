<UserControl x:Class="TaskPlannerClient.Views.Tabs.Manager.TasksManagementTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Manager"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="CreateButton" Content="Создать задачу" Style="{StaticResource MaterialDesignRaisedButton}" Click="CreateButton_Click"/>
            <Button x:Name="RefreshButton" Content="Обновить" Style="{StaticResource MaterialDesignFlatButton}" Margin="10,0,0,0" Click="RefreshButton_Click"/>
            <!-- Новые кнопки -->
            <Button x:Name="KanbanButton" Content="Канбан" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="10,0,0,0" Click="KanbanButton_Click"/>
            <Button x:Name="MatrixButton" Content="Матрица" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="10,0,0,0" Click="MatrixButton_Click"/>

            <Button x:Name="CalendarButton" Content="Календарь" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="10,0,0,0" Click="CalendarButton_Click"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!--поиск-->
            <!-- Добавьте этот элемент в Grid фильтров, например после кнопки "Сбросить" -->
            <TextBox x:Name="SearchTextBox" 
                 materialDesign:HintAssist.Hint="Поиск по названию или ID"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,5,5,0" Grid.Row="1" Grid.ColumnSpan="2"
                 TextChanged="SearchTextBox_TextChanged"/>

            <!-- Проект -->
            <ComboBox x:Name="FilterProjectCombo" Grid.Column="0" Margin="0,0,5,0"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="Проект"
                      DisplayMemberPath="ProjectName" SelectedValuePath="IdProject"
                      SelectionChanged="Filter_SelectionChanged"/>

            <!-- Статус -->
            <ComboBox x:Name="FilterStatusCombo" Grid.Column="1" Margin="0,0,5,0"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="Статус"
                      DisplayMemberPath="Name" SelectedValuePath="Id"
                      SelectionChanged="Filter_SelectionChanged"/>
            
            <ComboBox x:Name="FilterAssigneeCombo" Grid.Column="2" Grid.Row="1" Margin="0,5,5,0"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="Исполнитель"
                      SelectedValuePath="IdEmployee"
                      SelectionChanged="Filter_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding LastName}"/>
                            <TextBlock Text=" "/>
                            <TextBlock Text="{Binding FirstName}"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Спринт -->
            <ComboBox x:Name="FilterSprintCombo" Grid.Column="2" Margin="0,0,5,0"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="Спринт"
                      DisplayMemberPath="SprintName" SelectedValuePath="IdSprint"
                      SelectionChanged="Filter_SelectionChanged"/>

            <Button x:Name="ClearFiltersButton" Grid.Column="4" Content="Сбросить" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="ClearFiltersButton_Click"/>
        </Grid>

        <!-- Таблица задач -->
        <DataGrid x:Name="TasksDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status.Name}" Width="75"/>
                <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority.Name}" Width="90"/>
                <DataGridTextColumn Header="Исполнитель" Binding="{Binding Assignee.LastName}" Width="100"/>
                <DataGridTextColumn Header="Проект" Binding="{Binding Project.Name}" Width="120"/>
                <DataGridTextColumn Header="Спринт" Binding="{Binding Sprint.Name}" Width="120"/>
                <DataGridTextColumn Header="Дедлайн" Binding="{Binding Deadline, StringFormat='yyyy-MM-dd'}" Width="110"/>
                <DataGridTemplateColumn Header="Действия" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏️" ToolTip="Редактировать" Style="{StaticResource MaterialDesignIconButton}"
                                        Click="EditButton_Click" Tag="{Binding}"/>
                                <!--<Button Content="🔄" ToolTip="Сменить статус" Style="{StaticResource MaterialDesignIconButton}"
                                        Click="StatusButton_Click" Tag="{Binding}"/>-->
                                <Button Content="🗑️" ToolTip="Удалить" Style="{StaticResource MaterialDesignIconButton}"
                                        Click="DeleteButton_Click" Tag="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

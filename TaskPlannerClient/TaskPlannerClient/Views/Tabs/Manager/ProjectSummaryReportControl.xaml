<UserControl x:Class="TaskPlannerClient.Views.Tabs.Manager.ProjectSummaryReportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Manager"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox x:Name="ProjectCombo" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="ProjectName" SelectedValuePath="IdProject"
                      materialDesign:HintAssist.Hint="Проект"
                      Width="250" SelectionChanged="ProjectCombo_SelectionChanged"/>
            <Button Content="Диаграмма отклонений" Click="DeviationChartButton_Click" 
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Margin="10,0,0,0" HorizontalAlignment="Right"/>
        </StackPanel>

        <TextBlock x:Name="SummaryText" Grid.Row="1" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <DataGrid x:Name="TasksGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Задача" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="План (ч)" Binding="{Binding EstimateHours}" Width="120"/>
                <DataGridTextColumn Header="Факт (ч)" Binding="{Binding ActualHours}" Width="120"/>
                <DataGridTextColumn Header="В работе (ч)" Binding="{Binding WorkHours}" Width="120"/>
                <DataGridTextColumn Header="Ревью (ч)" Binding="{Binding ReviewHours}" Width="100"/>
                <DataGridTextColumn Header="Тест (ч)" Binding="{Binding TestHours}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="TotalText" Grid.Row="3" FontSize="12" Margin="0,10,0,0"/>
    </Grid>
</UserControl>

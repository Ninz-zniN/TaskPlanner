<UserControl x:Class="TaskPlannerClient.Views.Tabs.Worker.MyLoadTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Worker"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="600">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="Margin" Value="0,10,0,0"/>
            </Style.Setters>
        </Style>
    </UserControl.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="SprintInfoText" FontSize="20" FontWeight="Bold" 
                   Grid.Row="0" Margin="0,0,0,15" TextWrapping="Wrap"/>

        <Border Background="{StaticResource MaterialDesignCardBackground}" 
                CornerRadius="8" Padding="10" Grid.Row="1" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Моя нагрузка" FontSize="26" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Текущая нагрузка (часы):" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CurrentLoadText" Grid.Row="0" Grid.Column="1" Margin="20,10,0,0"/>

                    <TextBlock Text="Доступная ёмкость (часы):" Grid.Row="1" Grid.Column="0" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CapacityText" Grid.Row="1" Grid.Column="1" Margin="20,10,0,0"/>

                    <TextBlock Text="Процент загрузки:" Grid.Row="2" Grid.Column="0" FontWeight="SemiBold"/>
                    <TextBlock x:Name="LoadPercentText" Grid.Row="2" Grid.Column="1" Margin="20,10,0,0"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

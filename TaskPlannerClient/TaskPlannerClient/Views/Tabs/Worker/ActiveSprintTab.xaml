<UserControl x:Class="TaskPlannerClient.Views.Tabs.Worker.ActiveSprintTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Worker"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="500">
    <UserControl.Resources>
        <!-- Стиль для подписей (левая колонка) -->
        <Style x:Key="SprintLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
        <!-- Стиль для значений (правая колонка) -->
        <Style x:Key="SprintValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="20,10,0,0"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Border Background="{StaticResource MaterialDesignCardBackground}" 
                CornerRadius="8" Padding="20" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Активный спринт" FontSize="26" FontWeight="Bold" Margin="0,0,0,15"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0"
                               Style="{StaticResource SprintLabelStyle}"/>
                    <TextBlock x:Name="SprintNameText" Grid.Row="0" Grid.Column="1"
                               Style="{StaticResource SprintValueStyle}"/>

                    <TextBlock Text="Дата начала:" Grid.Row="1" Grid.Column="0"
                               Style="{StaticResource SprintLabelStyle}"/>
                    <TextBlock x:Name="StartDateText" Grid.Row="1" Grid.Column="1"
                               Style="{StaticResource SprintValueStyle}"/>

                    <TextBlock Text="Дата окончания:" Grid.Row="2" Grid.Column="0"
                               Style="{StaticResource SprintLabelStyle}"/>
                    <TextBlock x:Name="EndDateText" Grid.Row="2" Grid.Column="1"
                               Style="{StaticResource SprintValueStyle}"/>

                    <TextBlock Text="Рабочих дней:" Grid.Row="3" Grid.Column="0"
                               Style="{StaticResource SprintLabelStyle}"/>
                    <TextBlock x:Name="WorkDaysText" Grid.Row="3" Grid.Column="1"
                               Style="{StaticResource SprintValueStyle}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

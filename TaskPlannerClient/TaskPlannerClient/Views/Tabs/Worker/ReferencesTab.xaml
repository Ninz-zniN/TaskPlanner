<UserControl x:Class="TaskPlannerClient.Views.Tabs.Worker.ReferencesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Worker"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Типы задач -->
        <GroupBox Header="Типы задач" Grid.Column="0" Margin="5" Style="{StaticResource MaterialDesignCardGroupBox}">
            <DataGrid x:Name="TaskTypesGrid" AutoGenerateColumns="True" IsReadOnly="True" 
                      HeadersVisibility="Column" CanUserAddRows="False"/>
        </GroupBox>

        <!-- Статусы -->
        <GroupBox Header="Статусы" Grid.Column="1" Margin="5" Style="{StaticResource MaterialDesignCardGroupBox}">
            <DataGrid x:Name="TaskStatusesGrid" AutoGenerateColumns="True" IsReadOnly="True"
                      HeadersVisibility="Column" CanUserAddRows="False"/>
        </GroupBox>

        <!-- Приоритеты -->
        <GroupBox Header="Приоритеты" Grid.Column="2" Margin="5" Style="{StaticResource MaterialDesignCardGroupBox}">
            <DataGrid x:Name="PrioritiesGrid" AutoGenerateColumns="True" IsReadOnly="True"
                      HeadersVisibility="Column" CanUserAddRows="False"/>
        </GroupBox>
    </Grid>
</UserControl>

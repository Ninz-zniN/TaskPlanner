<UserControl x:Class="TaskPlannerClient.Views.Tabs.Common.KanbanTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:TaskPlannerClient.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:TaskPlannerClient.Views.Tabs.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Margin="10">
        <!-- Горизонтальная прокрутка перетаскиванием -->
        <ScrollViewer x:Name="MainScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
              PreviewMouseDown="MainScrollViewer_MouseDown"
              PreviewMouseMove="MainScrollViewer_MouseMove"
              PreviewMouseUp="MainScrollViewer_MouseUp">
            <ItemsControl x:Name="ColumnsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="300" Margin="0,0,10,0"
                                Background="{DynamicResource MaterialDesignCardBackground}" 
                                CornerRadius="8" Padding="0"
                                Effect="{DynamicResource MaterialDesignShadowDepth1}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Заголовок колонки -->
                                <ContentControl Background="{Binding HeaderBackground}" 
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center"
                                    Padding="12,10" MouseDoubleClick="Header_MouseDoubleClick">
                                    <ContentControl.Template>
                                        <ControlTemplate TargetType="ContentControl">
                                            <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </ContentControl.Template>
                                    <TextBlock Text="{Binding StatusName}" FontWeight="Bold" FontSize="16" Foreground="#1E1E1E"/>
                                </ContentControl>
                                
                                <!-- Список задач с вертикальной прокруткой перетаскиванием -->
                                <ListBox Grid.Row="1" ItemsSource="{Binding Tasks}" 
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.PanningMode="VerticalOnly"
                                         BorderThickness="0"
                                         AllowDrop="True"
                                         SelectionMode="Single"
                                         Drop="Column_Drop"
                                         Margin="8,8,8,8"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialListBoxItem}">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TaskCard_MouseDown"/>
                                            <EventSetter Event="MouseMove" Handler="TaskCard_MouseMove"/>
                                            <EventSetter Event="MouseDoubleClick" Handler="TaskCard_MouseDoubleClick"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource MaterialDesignPaper}" 
                CornerRadius="6" Padding="10" Margin="2"
                HorizontalAlignment="Stretch">
                                                <Grid>
                                                    <!-- Основное содержимое -->
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" FontSize="14"/>
                                                        <StackPanel Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding Priority.Name}" FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                                            <TextBlock Text="{Binding Deadline, StringFormat='dd.MM.yyyy'}" FontSize="12" Margin="0,2,0,0" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                                            <!-- Исполнитель (виден только если ShowAssignee=true) -->
                                                            <TextBlock Text="{Binding Assignee.LastName}" FontSize="12" Margin="0,2,0,0"
                                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                               Visibility="{Binding DataContext.ShowAssignee, 
                                                                   RelativeSource={RelativeSource AncestorType={x:Type ListBox}},
                                                                   Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <!-- Значок ожидания -->
                                                    <TextBlock Text="⏳" FontSize="16" 
                                                       HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,4,0"
                                                       Visibility="{Binding IsAwaiting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

<Window x:Class="TaskPlannerClient.Views.ProjectEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:TaskPlannerClient.Views"
        mc:Ignorable="d"
        Title="Проект" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Название -->
        <TextBlock Text="Название" FontWeight="Bold" Grid.Row="0"/>
        <TextBox x:Name="ProjectNameTextBox" Grid.Row="1" Margin="0,5,0,10"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <!-- Описание -->
        <TextBlock Text="Описание" FontWeight="Bold" Grid.Row="2"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="3" Margin="0,5,0,10"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 TextWrapping="Wrap" Height="80" AcceptsReturn="True"/>

        <!-- Статус -->
        <TextBlock Text="Статус" FontWeight="Bold" Grid.Row="4"/>
        <ComboBox x:Name="StatusComboBox" Grid.Row="5" Margin="0,5,0,10"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      SelectedValuePath="Tag"
                      materialDesign:HintAssist.Hint="Статус"
                      materialDesign:HintAssist.IsFloating="False">
            <ComboBoxItem Tag="planning">Планирование</ComboBoxItem>
            <ComboBoxItem Tag="active">Активный</ComboBoxItem>
            <ComboBoxItem Tag="completed">Завершён</ComboBoxItem>
        </ComboBox>

        <!-- Менеджер -->
        <TextBlock Text="Менеджер" FontWeight="Bold" Grid.Row="6"/>
        <ComboBox x:Name="ManagerComboBox" Grid.Row="7" Margin="0,5,0,10"
          Style="{StaticResource MaterialDesignOutlinedComboBox}"
          materialDesign:HintAssist.Hint="Менеджер"
          materialDesign:HintAssist.IsFloating="False"
          SelectedValuePath="IdEmployee"
          VerticalAlignment="Top">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IdEmployee}" Value="-1">
                                        <Setter Property="Text" Value="— Не выбран —"/>
                                    </DataTrigger>
                                </Style.Triggers>
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <MultiBinding StringFormat="{}{0} {1} ({2})">
                                            <Binding Path="LastName"/>
                                            <Binding Path="FirstName"/>
                                            <Binding Path="Position"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Команда -->
        <TextBlock Text="Команда" FontWeight="Bold" Grid.Row="8"/>
        <ComboBox x:Name="TeamComboBox" Grid.Row="9" Margin="0,5,0,10"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="TeamName" SelectedValuePath="IdTeam"
                      materialDesign:HintAssist.Hint="Команда"
                      materialDesign:HintAssist.IsFloating="False"/>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="10">
            <Button x:Name="SaveButton" Content="Сохранить" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="SaveButton_Click" Margin="0,0,10,0"/>
            <Button Content="Отмена" IsCancel="True"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
        </StackPanel>
    </Grid>
</Window>
